# Hugging Face API Key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Firebase Admin Configuration (Backend)
# For the service account, you can paste the JSON content as a single string
# or just provide the path to the service account JSON file if you modify index.js
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...}
FIREBASE_DB_URL=https://your_project_id.firebaseio.com

PORT=4000
