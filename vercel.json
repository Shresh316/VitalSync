{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/analyze",
      "destination": "backend/index.js"
    },
    {
      "source": "/((?!api/|analyze|src/|node_modules/|@|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
